{
  "name": "xcss-language-support",
  "displayName": "XCSS Language Support",
  "description": "Soporte de sintaxis y resaltado para el lenguaje XCSS",
  "version": "0.0.1",
  "publisher": "tu-usuario",
  "repository": {
    "type": "git",
    "url": "https://github.com/tu-usuario/xcss-vscode"
  },
  "homepage": "https://github.com/tu-usuario/xcss-vscode/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/tu-usuario/xcss-vscode/issues"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "xcss",
    "css",
    "preprocessor",
    "language",
    "syntax"
  ],
  "license": "MIT",
  "contributes": {
    "languages": [
      {
        "id": "xcss",
        "aliases": [
          "XCSS",
          "xcss"
        ],
        "extensions": [
          ".xcss"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "xcss",
        "scopeName": "source.xcss",
        "path": "./syntaxes/xcss.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0"
  }
}