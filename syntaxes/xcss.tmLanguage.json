{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "XCSS",
  "scopeName": "source.xcss",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#mixins"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#css-properties"
    },
    {
      "include": "#css-selectors"
    },
    {
      "include": "#blocks"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.xcss",
          "match": "//.*$"
        },
        {
          "name": "comment.block.xcss",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.xcss",
          "match": "\\b(import|use|from|as|namespace)\\b"
        },
        {
          "name": "keyword.control.block.xcss",
          "match": "\\b(public|private|write)\\b"
        },
        {
          "name": "keyword.control.conditional.xcss",
          "match": "\\b(if|else|switch|case|default)\\b"
        },
        {
          "name": "keyword.control.loop.xcss",
          "match": "\\b(for|while|in|break)\\b"
        },
        {
          "name": "keyword.control.function.xcss",
          "match": "\\b(define|return|throw|self)\\b"
        },
        {
          "name": "keyword.other.xcss",
          "match": "\\b(const|null|true|false|auto)\\b"
        }
      ]
    },
    "variables": {
      "name": "variable.other.xcss",
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_-]*"
    },
    "functions": {
      "begin": "(define)\\s+(\\$[a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\(",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.function.xcss"
        },
        "2": {
          "name": "entity.name.function.xcss"
        }
      },
      "end": "\\)",
      "patterns": [
        {
          "include": "#variables"
        },
        {
          "include": "#type-annotations"
        }
      ]
    },
    "mixins": {
      "begin": "(define)\\s+(mixin)\\s+(\\$[a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\(",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.function.xcss"
        },
        "2": {
          "name": "keyword.other.xcss"
        },
        "3": {
          "name": "entity.name.function.xcss"
        }
      },
      "end": "\\)",
      "patterns": [
        {
          "include": "#variables"
        }
      ]
    },
    "type-annotations": {
      "name": "storage.type.xcss",
      "match": ":\\s*(int|float|string|boolean|color|list|json|void)\\b"
    },
    "numbers": {
      "name": "constant.numeric.xcss",
      "match": "\\b\\d+(\\.\\d+)?(px|em|rem|%|vh|vw|deg|rad|ms|s)?\\b"
    },
    "strings": {
      "name": "string.quoted.double.xcss",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.xcss",
          "match": "\\\\."
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.xcss",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.xcss",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.xcss",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.logical.xcss",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.ternary.xcss",
          "match": "\\?|:"
        },
        {
          "name": "keyword.operator.scope.xcss",
          "match": "\\$\\$"
        }
      ]
    },
    "css-properties": {
      "name": "support.type.property-name.css",
      "match": "\\b(background|color|margin|padding|border|width|height|max-width|min-width|max-height|min-height|font-size|font-family|font-weight|text-align|display|position|top|right|bottom|left|flex|grid|opacity|z-index|overflow|cursor|transition|transform|animation)\\b(?=\\s*:)"
    },
    "css-selectors": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.class.css",
          "match": "\\.[a-zA-Z_][a-zA-Z0-9_-]*"
        },
        {
          "name": "entity.other.attribute-name.id.css",
          "match": "#[a-zA-Z_][a-zA-Z0-9_-]*"
        },
        {
          "name": "entity.name.tag.css",
          "match": "\\b(body|div|span|p|h1|h2|h3|h4|h5|h6|a|img|ul|ol|li|table|tr|td|th|form|input|button|nav|header|footer|section|article|aside)\\b"
        },
        {
          "name": "entity.other.pseudo-class.css",
          "match": ":\\b(hover|active|focus|visited|first-child|last-child|nth-child|not|disabled|checked)\\b"
        },
        {
          "name": "entity.other.pseudo-element.css",
          "match": "::\\b(before|after|first-line|first-letter|selection)\\b"
        },
        {
          "name": "keyword.other.parent-selector.css",
          "match": "&"
        }
      ]
    },
    "blocks": {
      "name": "meta.structure.block.xcss",
      "begin": "{",
      "end": "}",
      "patterns": [
        {
          "include": "#css-properties"
        },
        {
          "include": "#css-selectors"
        },
        {
          "include": "#variables"
        },
        {
          "include": "#keywords"
        },
        {
          "include": "#functions"
        },
        {
          "include": "#mixins"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#operators"
        }
      ]
    }
  }
}